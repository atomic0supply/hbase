rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    // ---- users: each person owns only their own profile doc ----
    match /users/{uid} {
      allow read, write: if signedIn() && request.auth.uid == uid;
    }

    // ---- households: shared state for a pair ----
    match /households/{hid} {
      function isMember() {
        return signedIn() && request.auth.uid in resource.data.members;
      }

      // A signed-in user can create a household with themselves as the sole member.
      allow create: if signedIn()
        && request.resource.data.createdBy == request.auth.uid
        && request.resource.data.members.size() == 1
        && request.resource.data.members[0] == request.auth.uid;

      // Existing members can read and edit freely.
      allow read: if isMember();
      allow update: if isMember() || isValidJoin();

      // No client deletes.
      allow delete: if false;

      // A non-member may join (add themselves) only if they present a valid invite
      // code (written into joinCode) whose invite points at this household, and the
      // member list grows by exactly one to a maximum of two.
      function isValidJoin() {
        return signedIn()
          && !(request.auth.uid in resource.data.members)
          && request.auth.uid in request.resource.data.members
          && request.resource.data.members.size() == resource.data.members.size() + 1
          && request.resource.data.members.size() <= 2
          && request.resource.data.members.hasAll(resource.data.members)
          && request.resource.data.joinCode is string
          && exists(/databases/$(database)/documents/invites/$(request.resource.data.joinCode))
          && get(/databases/$(database)/documents/invites/$(request.resource.data.joinCode)).data.householdId == hid;
      }
    }

    // ---- invites: code -> householdId. The code itself is the shared secret. ----
    match /invites/{code} {
      // Any signed-in user can read an invite they hold the code for.
      allow read: if signedIn();

      // Only a member of the target household can create an invite for it.
      allow create: if signedIn()
        && request.resource.data.createdBy == request.auth.uid
        && request.resource.data.householdId is string
        && request.auth.uid in get(/databases/$(database)/documents/households/$(request.resource.data.householdId)).data.members;

      // Invites are immutable; they can be consumed (deleted) by a member of the household.
      allow update: if false;
      allow delete: if signedIn()
        && request.auth.uid in get(/databases/$(database)/documents/households/$(resource.data.householdId)).data.members;
    }
  }
}
